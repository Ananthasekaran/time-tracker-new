pipeline {
    agent any

    tools {
        maven 'Maven'      // Jenkins Maven tool name
    }

    environment {
        DOCKER_IMAGE = 'mypro'
    }

    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'master', url: 'https://github.com/Msocial123/EcommerceApp.git'
            }
        }

        stage('Build Maven Project') {
            steps {
                dir('EcommerceApp') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('EcommerceApp') {
                    sh 'docker build -t $DOCKER_IMAGE .'
                }
            }
        }

        stage('Stop Existing Container') {
            steps {
                sh '''
                docker stop $DOCKER_IMAGE || true
                docker rm $DOCKER_IMAGE || true
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d --name $DOCKER_IMAGE -p 8080:8080 $DOCKER_IMAGE'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful! App is live on port 8080.'
        }
        failure {
            echo 'Build or Deployment Failed!'
        }
    }
}